# Keychron M6 8K — hidraw access rules.
#
# Grants the active desktop user read+write access to the M6's hidraw nodes
# via the `uaccess` tag (managed by systemd-logind). This is narrower than
# world-readable mode and only applies to the matching device.
#
# Install:
#   sudo cp 99-keychron-m6-8k.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
# Then unplug + replug the receiver / cable.

# USB-direct M6 (wired charging mode).
SUBSYSTEM=="hidraw", KERNEL=="hidraw*", \
    ATTRS{idVendor}=="3434", ATTRS{idProduct}=="d049", TAG+="uaccess"

# Ultra-Link 8K receiver (wireless mode).
SUBSYSTEM=="hidraw", KERNEL=="hidraw*", \
    ATTRS{idVendor}=="3434", ATTRS{idProduct}=="d028", TAG+="uaccess"
